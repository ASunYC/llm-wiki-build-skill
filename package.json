{
  "name": "llm-wiki-build-skill",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Reusable skill scripts for building SQLite-backed LLM Wiki knowledge bases and knowledge graphs.",
  "keywords": [
    "llm-wiki",
    "wiki",
    "knowledge-base",
    "knowledge-graph",
    "agent-skills",
    "agent",
    "claude-code",
    "codex",
    "opencode",
    "sqlite",
    "better-sqlite3",
    "markdown",
    "rag",
    "graph",
    "static-viewer"
  ],
  "scripts": {
    "cli": "node scripts/llm-wiki.mjs",
    "init": "node scripts/init-wiki.mjs",
    "ingest": "node scripts/ingest-docs.mjs",
    "graph": "node scripts/build-graph.mjs",
    "query": "node scripts/query-wiki.mjs",
    "llm:status": "node scripts/llm-status.mjs",
    "llm:test": "node scripts/test-llm.mjs",
    "llm:extract": "node scripts/extract-llm.mjs",
    "lint": "node scripts/lint-wiki.mjs",
    "reingest": "node scripts/reingest.mjs"
  },
  "dependencies": {
    "better-sqlite3": "^12.4.6"
  }
}
